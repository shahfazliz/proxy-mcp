{
  "name": "@shahfazliz/proxy-mcp",
  "version": "0.1.0",
  "description": "MCP server running a local HTTPS MITM proxy to mock headend/backend responses on real QA devices at the network level.",
  "type": "module",
  "bin": {
    "proxy-mcp": "dist/index.js",
    "proxy-mcp-cli": "dist/cli.js"
  },
  "files": ["dist/"],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "dev": "tsx src/index.ts",
    "ca:status": "tsx src/ca.ts",
    "ca:import": "tsx src/ca.ts import",
    "start": "node dist/index.js",
    "cli": "tsx src/cli.ts"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "mockttp": "^4.4.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0"
  }
}
